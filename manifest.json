{
  "manifest_version": 3,
  "name": "ChatGPT User Prompt",
  "description": "ChatGPT User Prompt",
  "version": "1.5.1",
  "action": {
    "default_popup": "main.html",
    "default_icon": {
      "16": "images/icon.png"
    }
  },
  "permissions": ["activeTab", "storage"],
  "web_accessible_resources": [
    {
      "resources": [
        "*.css", "*.html", "*.json"
      ],
      "matches": [
        "https://chatgpt.com/*",
        "https://gemini.google.com/*",
        "https://claude.ai/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://gemini.google.com/*",
        "https://claude.ai/*"
      ],
      "js": ["scripts/content.js"]
    }
  ]
}
